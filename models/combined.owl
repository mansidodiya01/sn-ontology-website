  <rdf:Description rdf:about="">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dc:title xml:lang="en">Surya Namaskar Sequence Ontology</dc:title>
    <dc:description xml:lang="en">Ontology of Surya Namaskar poses, sequence steps, and variants. It models a base SN sequence and three variants, and supports queries about repeated steps, inverse steps, standing support, next or previous steps, and shared poses across variants.</dc:description>
  </rdf:Description>
