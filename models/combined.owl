  <rdf:Description rdf:about="">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dc:title xml:lang="en">Surya Namaskar Ontology</dc:title>
    <dc:description xml:lang="en">Ontology of Surya Namaskar asanas, pose occurrences, and variants. It models one base sequence and three variants, and supports queries about ordered poses, repeated poses, support type, mantra, chakra, alternate names, and shared asanas across variants.</dc:description>
  </rdf:Description>
